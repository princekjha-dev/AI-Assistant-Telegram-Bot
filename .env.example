# Bot Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# REQUIRED CREDENTIALS
# ============================================================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ============================================================================
# OPTIONAL API KEYS
# ============================================================================
HF_API_TOKEN=
REPLICATE_API_TOKEN=

# ============================================================================
# LLM CONFIGURATION
# ============================================================================
LLM_PROVIDER=openrouter
PRIMARY_MODEL=openai/gpt-4-turbo
FALLBACK_MODEL=anthropic/claude-3-sonnet
LIGHTWEIGHT_MODEL=meta-llama/llama-2-70b-chat
IMAGE_GENERATION_MODEL=stabilityai/stable-diffusion-3

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_IMAGE_GENERATION=true
ENABLE_VOICE=true
ENABLE_WEB_SEARCH=false
ENABLE_ANALYTICS=true
ENABLE_PREMIUM_FEATURES=false

# ============================================================================
# PERFORMANCE
# ============================================================================
MAX_RESPONSE_TOKENS=2000
TEMPERATURE=0.7
TOP_P=1.0
CONTEXT_WINDOW_SIZE=10
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW=60

# ============================================================================
# PATHS & STORAGE
# ============================================================================
DATABASE_PATH=./data/bot_database.db
DATABASE_BACKUP_PATH=./data/backups
MEDIA_STORAGE_PATH=./data/media
GENERATED_IMAGES_PATH=./data/generated_images
LOG_FILE=./logs/bot.log

# ============================================================================
# DEPLOYMENT
# ============================================================================
ENVIRONMENT=development
POLLING_MODE=true
WEBHOOK_URL=
HOST=0.0.0.0
PORT=8080
DEBUG_MODE=false
LOG_LEVEL=INFO
